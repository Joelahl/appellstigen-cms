FROM node:20-alpine
RUN apk add --no-cache libc6-compat python3 make g++
WORKDIR /app
COPY package*.json ./
RUN npm ci --legacy-peer-deps
COPY . .
# Apply committed migrations (from src/migrations). Idempotent: already-applied
# migrations are skipped. New schema changes are added by running
# `payload migrate:create` locally and committing the generated files.
CMD ["sh", "-c", "node_modules/.bin/cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts node_modules/.bin/payload migrate 2>&1"]
