FROM node:20-alpine
RUN apk add --no-cache libc6-compat python3 make g++
WORKDIR /app
COPY package*.json ./
RUN npm ci --legacy-peer-deps
COPY . .
# Generate the initial migration file from the current schema, then apply it
CMD ["sh", "-c", "node_modules/.bin/cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts node_modules/.bin/payload migrate:create --name init 2>&1 || true && node_modules/.bin/cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts node_modules/.bin/payload migrate 2>&1"]
